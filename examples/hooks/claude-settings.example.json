{
  "statusLine": {
    "type": "command",
    "command": "TOKENBAR_BIN=\"${CLAUDE_PROJECT_DIR}/bin/tokenbar\" \"${CLAUDE_PROJECT_DIR}/examples/hooks/claude-tokenbar-statusline.sh\"",
    "padding": 0
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "TOKENBAR_BIN=\"${CLAUDE_PROJECT_DIR}/bin/tokenbar\" \"${CLAUDE_PROJECT_DIR}/examples/hooks/claude-tokenbar-user-prompt-submit.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
